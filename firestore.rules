rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Roles: student, parent, admin
    // Fields: uid, email, role, school, graduationYear, createdAt
    //
    // Collection: events
    // Fields: name, date, location, mapUrl, description
    //
    // Collection: events/{eventId}/seminars
    // Fields: title, speaker, time, room
    //
    // Collection: users/{userId}/registrations
    // Fields: eventId, registeredAt, status
    //
    // Collection: users/{userId}/notifications
    // Fields: title, message, type, read, createdAt
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "corey@ncrfoundation.org" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.role in ['student', 'parent', 'admin', 'recruiter'] &&
             data.email is string &&
             data.email.size() > 0 && data.email.size() < 100;
    }

    function isValidLead(data) {
      return data.keys().hasAll(['recruiterId', 'studentId', 'studentEmail', 'scannedAt']) &&
             data.recruiterId == request.auth.uid &&
             data.studentEmail is string && data.studentEmail.size() > 0;
    }

    function isValidEvent(data) {
      return data.keys().hasAll(['name', 'date', 'location', 'city', 'description', 'status']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.status in ['published', 'draft'] &&
             data.date is string && data.city is string && data.location is string;
    }

    function isValidSeminar(data) {
      return data.keys().hasAll(['title', 'time', 'status']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.status in ['published', 'draft'];
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['title', 'message', 'userId']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200;
    }

    function isValidRegistration(data) {
      return data.keys().hasAll(['eventId', 'registeredAt']) &&
             data.eventId is string &&
             data.registeredAt is string;
    }

    function isValidFeedback(data) {
      return data.keys().hasAll(['userId', 'rating', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             (data.comment == null || (data.comment is string && data.comment.size() < 1000));
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /leads/{leadId} {
      allow read: if isAuthenticated() && (resource.data.recruiterId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidLead(request.resource.data);
      allow update, delete: if isAuthenticated() && (resource.data.recruiterId == request.auth.uid || isAdmin());
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) &&
                      (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) &&
                      (isOwner(userId) && request.resource.data.role == resource.data.role || isAdmin());
      
      match /notifications/{notifId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update, delete: if isAdmin();
        allow update: if isOwner(userId) && 
                         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      }

      match /registrations/{eventId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if (isOwner(userId) || isAdmin()) && isValidRegistration(request.resource.data);
        allow delete: if (isOwner(userId) || isAdmin());
      }
    }

    match /events/{eventId} {
      allow read: if resource == null || resource.data.status != 'draft' || isAdmin();
      allow create, update, delete: if isAdmin();

      match /seminars/{seminarId} {
        allow read: if resource == null || resource.data.status != 'draft' || isAdmin();
        allow create, update, delete: if isAdmin();
      }

      match /feedback/{feedbackId} {
        allow read: if true;
        allow create: if isAuthenticated() && isValidFeedback(request.resource.data);
        allow update, delete: if isAdmin();
      }

      match /sponsors/{sponsorId} {
        allow read: if true;
        allow create, update, delete: if isAdmin();
      }

      match /updates/{updateId} {
        allow read: if true;
        allow create, update, delete: if isAdmin();
      }
    }
  }
}
